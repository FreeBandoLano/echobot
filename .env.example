# RadioSynopsis Configuration Example
# Copy this file to .env and customize your settings

# ============================================
# AI/ML Configuration (REQUIRED)
# ============================================
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# Audio Source Configuration (CHOOSE ONE)
# ============================================
# Option 1: Radio Stream URL (recommended for cloud deployment)
RADIO_STREAM_URL=https://your-radio-station-stream-url-here

# Option 2: Local Audio Input Device (for local recording)
# AUDIO_INPUT_DEVICE=default
# AUDIO_INPUT_DEVICE="Stereo Mix (Realtek(R) Audio)"

# ============================================
# Station/Program Configuration
# ============================================
STATION_NAME=Your Radio Station
PROGRAM_NAME=Your Program Name
TARGET_AUDIENCE=your target audience
ORGANIZATION_TYPE=radio station type
CONTENT_FOCUS=content areas to focus on
SUMMARY_STYLE=summary style preference

# ============================================
# Scheduling Configuration
# ============================================
# All times in station timezone
TZ=Your/Timezone

# Block A - Example Morning Block
BLOCK_A_START=10:00
BLOCK_A_END=12:00

# Block B - Example Afternoon Block
BLOCK_B_START=14:00
BLOCK_B_END=16:00

# Block C - Example Evening Block  
BLOCK_C_START=18:00
BLOCK_C_END=20:00

# Block D - Example Late Block
BLOCK_D_START=20:00
BLOCK_D_END=22:00

# ============================================
# Application Settings
# ============================================
# Web interface settings
API_HOST=0.0.0.0
API_PORT=8001

# Processing settings
MAX_SUMMARY_LENGTH=1000
ENABLE_DETAILED_QUOTES=true

# Development/Debug settings (disable in production)
ENABLE_DEBUG_ENDPOINTS=false

# ============================================
# Storage Paths (optional - defaults provided)
# ============================================
# AUDIO_DIR=./audio
# TRANSCRIPTS_DIR=./transcripts
# SUMMARIES_DIR=./summaries
# WEB_DIR=./web_output
